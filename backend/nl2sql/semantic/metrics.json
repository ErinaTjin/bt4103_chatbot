{
  "metrics": [
    {
      "name": "count_patients",
      "description": "Number of patients",
      "table": "person",
      "expression": "person_id",
      "aggregation": "count"
    }, 
    {
      "name": "avg_age",
      "description": "Average age of patients",
      "table": "person",
      "expression": "YEAR(CURRENT_DATE) - year_of_birth",
      "aggregation": "avg"
    }
  ]
}
