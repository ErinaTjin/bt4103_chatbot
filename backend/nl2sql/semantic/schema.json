{
  "tables": {
    "person": {
      "description": "Patient demographic information",
      "columns": [
        {
          "name": "person_id",
          "type": "int",
          "description": "unique identifier that joins this table to other tables"
        },
        {
          "name": "gender_source_value",
          "type": "str",
          "description": "gender of patient"
        },
        {
          "name": "year_of_birth",
          "type": "int",
          "description": "use to calculate age: YEAR(CURRENT_DATE) - year_of_birth"
        },
        {
          "name": "race_concept_value",
          "type": "int",
          "description": "race as a concept id. 38003579 = Chinese, 41949700 = Malay, 38003574 = Indian, 8515 = Asian Other, NULL = Other."
        }
      ]
    },

    "condition_occurrence": {
      "description": "Condition of patient",
      "columns": [
        {
          "name": "person_id",
          "type": "int",
          "description": "use to join to person"
        },
        {
          "name": "condition_occurrence_id",
          "type": "int",
          "description": "primary key"
        },
        {
          "name": "condition_start_date",
          "type": "date",
          "description": "date of diagnosis"
        },
        {
          "name": "condition_source_value",
          "type": "str",
          "description": "condition: topo code || topo description || histo code || histo description"
        }
      ]
    },

    "procedure_occurrence": {
      "description": "Surgery and radiotherapy information",
      "columns": [
        {
          "name": "person_id",
          "type": "int",
          "description": "use to join to person"
        },
        {
          "name": "procedure_occurrence_id",
          "type": "int",
          "description": "primary key"
        },
        {
          "name": "institution",
          "type": "str",
          "description": "location of surgery"
        },
        {
          "name": "procedure_concept_id",
          "type": "int",
          "description": "concept ID of procedure, NULL for surgery"
        },
        {
          "name": "procedure_source_value",
          "type": "str",
          "description": "source description of surgery or radiotherapy"
        },
        {
          "name": "procedure_datetime",
          "type": "date",
          "description": "start date and time of procedure"
        },
        {
          "name": "procedure_end_datetime",
          "type": "date",
          "description": "end date and time of procedure"
        },
        {
          "name": "TOSP",
          "type": "str",
          "description": "table of surgical procedures, usually used for billing classification"
        }
      ]
    },

    "measurement_mutation": {
      "description": "Staging, mutation, grade, laterality information",
      "columns": [
        {
          "name": "person_id",
          "type": "int",
          "description": "use to join to person"
        },
        {
          "name": "measurement_id",
          "type": "int",
          "description": "primary key"
        },
        {
          "name": "institution",
          "type": "str",
          "description": "location of surgery"
        },
        {
          "name": "measurement_concept_name",
          "type": "str",
          "description": "type of measurement. key values: TNM Clin Stage Group, TNM Path Stage Group, TNM Clin T, TNM Clin N, TNM Clin M, BRAF Mutation Conclusion, KRAS Mutation Conclusion, NRAS Mutation Conclusion, APC Mutation Conclusion, Grade, Laterality"
        },
        {
          "name": "value_as_concept_name",
          "type": "str",
          "description": "result of the measurement, e.g. mutation detected, stage number/classification"
        },
        {
          "name": "measurement_event_id",
          "type": "int",
          "description": "use to join procedure_occurrence_id"
        }
      ]
    },

    "death": {
      "description": "Death records. Always left join so living patients are not excluded",
      "columns": [
        {
          "name": "person_id",
          "type": "int",
          "description": "use to join to person"
        },
        {
          "name": "death_date",
          "type": "date",
          "description": "date of death"
        },
        {
          "name": "cause_source_value",
          "type": "str",
          "description": "cause of death"
        }
      ]
    },

    "drug_exposure_cancerdrugs": {
      "description": "Cancer drug treatments",
      "columns": [
        {
          "name": "person_id",
          "type": "int",
          "description": "use to join to person"
        },
        {
          "name": "drug_exposure_id",
          "type": "int",
          "description": "primary key"
        },
        {
          "name": "drug_source_value",
          "type": "str",
          "description": "prescribed drug: NDC || Gemscript code"
        },
        {
          "name": "drug_procedure_start_date",
          "type": "date",
          "description": "start date of prescribed drug"
        },
        {
          "name": "drug_procedure_end_date",
          "type": "date",
          "description": "end date of prescribed drug"
        },
        {
          "name": "institution",
          "type": "str",
          "description": "location where drug was prescribed"
        }
      ]
    }
  },

  "joins": [
    {
      "left_table": "person",
      "right_table": "condition_occurrence",
      "left_key": "person_id",
      "right_key": "person_id",
      "join_type": "INNER"
    },
    {
      "left_table": "person",
      "right_table": "procedure_occurrence",
      "left_key": "person_id",
      "right_key": "person_id",
      "join_type": "INNER"
    },
    {
      "left_table": "person",
      "right_table": "measurement_mutation",
      "left_key": "person_id",
      "right_key": "person_id",
      "join_type": "INNER"
    },
    {
      "left_table": "person",
      "right_table": "death",
      "left_key": "person_id",
      "right_key": "person_id",
      "join_type": "LEFT"
    },
    {
      "left_table": "person",
      "right_table": "drug_exposure_cancerdrugs",
      "left_key": "person_id",
      "right_key": "person_id",
      "join_type": "INNER"
    }
  ]
}
